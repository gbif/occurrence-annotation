# API Configuration Template
# Copy this file to .env and configure for your environment

# Set mode to 'local' to use local backend, or 'production' to use GBIF API
VITE_API_MODE=production

# Local backend URL (only used when VITE_API_MODE=local)
VITE_LOCAL_API_BASE_URL=http://localhost:8080

# GBIF API URL for species lookups (always uses GBIF)
VITE_GBIF_API_BASE_URL=https://api.gbif.org/v1

# OpenAI API Key Configuration
# 
# ⚠️ SECURITY: OpenAI API keys are NOT configured via environment variables.
# 
# Why: VITE_* environment variables are embedded in the client JavaScript bundle
# and can be extracted by anyone inspecting the deployed application.
# 
# How to use OpenAI features:
# 1. Open the application in your browser
# 2. Click the Settings/OpenAI icon in the UI
# 3. Enter your personal OpenAI API key
# 4. Key is stored securely in your browser's localStorage only
# 
# Get your API key from: https://platform.openai.com/api-keys
# Set spending limits: https://platform.openai.com/settings/organization/limits
