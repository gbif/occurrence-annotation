# API Configuration Template
# Copy this file to .env and configure for your environment

# Set mode to 'local' to use local backend, or 'production' to use GBIF API
VITE_API_MODE=production

# Local backend URL (only used when VITE_API_MODE=local)
VITE_LOCAL_API_BASE_URL=http://localhost:8080

# GBIF API URL for species lookups (always uses GBIF)
VITE_GBIF_API_BASE_URL=https://api.gbif.org/v1

# ⚠️ WARNING: VITE_* variables are bundled into the browser and visible to all users!
# OpenAI API Key for AI-powered location quality checks (OPTIONAL admin fallback)
# 
# SECURITY NOTICE:
# - VITE_* environment variables are embedded in the client JavaScript bundle
# - Anyone can extract this key by inspecting your deployed application
# - This should ONLY be used for local development with spending limits set
# - For production, users must provide their own OpenAI API keys via the UI
# - Recommended: Leave this blank and require user-provided keys
#
# Get your API key from: https://platform.openai.com/api-keys
# Set spending limits: https://platform.openai.com/settings/organization/limits
# VITE_OPENAI_API_KEY=your_openai_api_key_here
